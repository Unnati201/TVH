# --- Gemini ---
GOOGLE_API_KEY=your-gemini-api-key
GEMINI_CHAT_MODEL=gemini-2.0-flash
GEMINI_EMBED_MODEL=text-embedding-004

# --- Pinecone ---
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX=tvh-labels-signs
PINECONE_CLOUD=gcp
PINECONE_REGION=us-central1

# --- Cloud SQL (Postgres) ---
# Local/dev: point at a local Postgres or the Cloud SQL Auth Proxy on localhost.
# Prod: use Cloud SQL Python Connector with IAM auth instead of a raw URL.
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/tvh_findability
